generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  USER
}

enum FileKind {
  IMAGE
  VIDEO
  AUDIO
  PDF
  TEXT
  CODE
  ARCHIVE
  OFFICE
  OTHER
}

model User {
  id              String         @id @default(cuid())
  username        String         @unique
  passwordHash    String
  role            UserRole       @default(USER)
  isActive        Boolean        @default(true)
  maxUploadBytes  BigInt?
  rootFolderId    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  folders         Folder[]
  files           FileEntry[]
  shares          Share[]        @relation("ShareCreator")
  sessions        Session[]
  auditLogs       AuditLog[]
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  ip          String?
  userAgent   String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Folder {
  id          String      @id @default(cuid())
  name        String
  ownerId     String
  parentId    String?
  path        String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parent      Folder?     @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]    @relation("FolderToFolder")
  files       FileEntry[]

  @@index([ownerId, parentId])
  @@unique([ownerId, path])
}

model FileEntry {
  id              String      @id @default(cuid())
  ownerId         String
  folderId        String?
  storageKey      String      @unique
  originalName    String
  extension       String?
  mimeType        String
  sizeBytes       BigInt
  kind            FileKind    @default(OTHER)
  checksumSha256  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  owner           User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  folder          Folder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  shareItems      ShareItem[]

  @@index([ownerId, folderId])
  @@index([kind])
}

model Share {
  id               String      @id @default(cuid())
  creatorId        String
  token            String      @unique
  passwordHash     String?
  expiresAt        DateTime?
  maxDownloads     Int?
  downloadCount    Int         @default(0)
  allowPreview     Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  creator          User        @relation("ShareCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  items            ShareItem[]
  accessLogs       ShareAccessLog[]

  @@index([creatorId])
  @@index([token])
}

model ShareItem {
  id        String    @id @default(cuid())
  shareId    String
  fileId     String
  createdAt  DateTime  @default(now())
  share      Share     @relation(fields: [shareId], references: [id], onDelete: Cascade)
  file       FileEntry @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([shareId, fileId])
}

model ShareAccessLog {
  id           String   @id @default(cuid())
  shareId       String
  accessedAt    DateTime @default(now())
  ip            String?
  userAgent     String?
  action        String
  share         Share    @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@index([shareId, accessedAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId      String
  action       String
  targetType   String
  targetId     String?
  detail       String?
  createdAt    DateTime @default(now())
  actor        User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
}
